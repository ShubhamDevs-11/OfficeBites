<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head') %>
        <style>
            :root {
                --brand-dark: #222222;
                --brand-darker: #1a1a1a;
                --brand-accent: #89e900;
                --brand-accent-hover: #9dff10;
                --panel: #2a2a2a;
                --border-col: #3a3a3a;
                --text-light: #f2f2f2;
                --text-muted: #a8a8a8;
                --danger: #ff5c5c;
                --danger-hover: #ff3d3d;
                --success: #6ee06e;
            }

            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
                background: radial-gradient(circle at top, #2b2b2b 0%, var(--brand-darker) 70%);
                color: var(--text-light);
                min-height: 100vh;
                padding: 0 0 40px 0;
            }

            .container {
                max-width: 1000px;
                margin: 40px auto;
                padding: 0 20px;
            }

            h2 {
                font-size: 26px;
                font-weight: 800;
                margin-bottom: 24px;
                letter-spacing: -0.5px;
                position: relative;
                padding-left: 14px;
            }

            h2::before {
                content: "";
                position: absolute;
                left: 0;
                top: 4px;
                bottom: 4px;
                width: 4px;
                background: var(--brand-accent);
                border-radius: 2px;
            }

            h3 {
                font-size: 17px;
                font-weight: 700;
                margin-bottom: 16px;
                padding-bottom: 10px;
                border-bottom: 1px solid var(--border-col);
                color: var(--text-light);
            }

            #message {
                margin-bottom: 24px;
                padding: 12px 14px;
                font-size: 14px;
                font-weight: 500;
                background-color: var(--panel);
                border: 1px solid var(--border-col);
                border-left: 4px solid var(--brand-accent);
                border-radius: 6px;
                color: var(--text-light);
            }

            #message:empty {
                display: none;
            }

            /* Responsive Split Layout */
            .management-grid {
                display: grid;
                grid-template-columns: 360px 1fr;
                gap: 32px;
                align-items: start;
            }

            @media (max-width: 850px) {
                .management-grid {
                    grid-template-columns: 1fr;
                }
            }

            .form-card {
                background: var(--panel);
                border: 1px solid var(--border-col);
                border-radius: 10px;
                padding: 24px;
                box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
            }

            .form-group {
                margin-bottom: 16px;
            }

            label {
                display: block;
                font-size: 13px;
                font-weight: 600;
                margin-bottom: 6px;
                color: var(--text-muted);
                text-transform: uppercase;
                letter-spacing: 0.4px;
            }

            input {
                width: 100%;
                padding: 10px 12px;
                font-size: 15px;
                border: 1px solid var(--border-col);
                border-radius: 8px;
                color: var(--text-light);
                background-color: #1f1f1f;
                transition: border-color 0.2s ease, box-shadow 0.2s ease;
            }

            input:focus {
                outline: none;
                border-color: var(--brand-accent);
                box-shadow: 0 0 0 3px rgba(137, 233, 0, 0.18);
                background-color: #232323;
            }

            button[type="submit"] {
                width: 100%;
                padding: 11px;
                font-size: 15px;
                font-weight: 700;
                color: #111111;
                background-color: var(--brand-accent);
                border: none;
                border-radius: 8px;
                cursor: pointer;
                margin-top: 8px;
                transition: background-color 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
            }

            button[type="submit"]:hover {
                background-color: var(--brand-accent-hover);
                box-shadow: 0 0 20px rgba(137, 233, 0, 0.35);
                transform: translateY(-1px);
            }

            /* Office Item List & Dynamic Cards */
            .office-list-container {
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
                gap: 16px;
            }

            .office-card {
                background: var(--panel) !important;
                border: 1px solid var(--border-col) !important;
                border-radius: 10px !important;
                padding: 20px !important;
                margin-bottom: 0 !important;
                box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3) !important;
                display: flex;
                flex-direction: column;
                justify-content: space-between;
                transition: border-color 0.2s ease, transform 0.15s ease;
            }

            .office-card:hover {
                border-color: rgba(137, 233, 0, 0.35) !important;
                transform: translateY(-2px);
            }

            .office-card p {
                font-size: 14px;
                margin-bottom: 6px;
                line-height: 1.4;
                color: var(--text-light);
            }

            .office-card p strong {
                font-size: 16px;
                color: var(--text-light);
                display: block;
                margin-bottom: 4px;
            }

            .office-actions {
                margin-top: 16px;
                display: flex;
                flex-direction: column;
                gap: 6px;
            }

            .office-card button {
                width: 100%;
                padding: 8px;
                font-size: 13px;
                font-weight: 600;
                border: none;
                border-radius: 6px;
                cursor: pointer;
                transition: background-color 0.2s ease, transform 0.15s ease;
            }

            .btn-toggle {
                background-color: var(--brand-accent);
                color: #111111;
            }

            .btn-toggle:hover {
                background-color: var(--brand-accent-hover);
            }

            .btn-row {
                display: flex;
                gap: 6px;
            }

            .btn-edit {
                background-color: #1f1f1f;
                color: var(--text-light);
                border: 1px solid var(--border-col) !important;
            }

            .btn-edit:hover {
                background-color: #292929;
            }

            .btn-remove {
                background-color: var(--danger);
                color: #111111;
            }

            .btn-remove:hover {
                background-color: var(--danger-hover);
            }
        </style>
</head>

<body>

    <%- include('../partials/nav') %>

        <div class="container">
            <h2>Offices</h2>

            <div id="message"></div>

            <div class="management-grid">
                <!-- Left Panel: Form Control -->
                <div class="form-card">
                    <h3>Add New Office</h3>
                    <form id="addForm">
                        <div class="form-group">
                            <label>Office Name</label>
                            <input type="text" name="officeName" required>
                        </div>
                        <div class="form-group">
                            <label>Address</label>
                            <input type="text" name="address" required>
                        </div>
                        <div class="form-group">
                            <label>Contact Number</label>
                            <input type="text" name="contactNumber" required>
                        </div>
                        <button type="submit">Add Office</button>
                    </form>
                </div>

                <!-- Right Panel: Grid Cards -->
                <div>
                    <h3>All Offices</h3>
                    <div id="officeList" class="office-list-container">
                        <p>Loading...</p>
                    </div>
                </div>
            </div>
        </div>

        <script>
            const messageBox = document.getElementById("message");
            const officeList = document.getElementById("officeList");

            // ─────────────────────────────────
            // LOAD ALL OFFICES
            // ─────────────────────────────────
            async function loadOffices() {
                try {
                    const res = await fetch("/api/owner/offices-data", {
                        credentials: "include",
                    });
                    const data = await res.json();

                    if (!res.ok) {
                        officeList.textContent = data.message;
                        return;
                    }

                    if (data.offices.length === 0) {
                        officeList.innerHTML = "<p>No offices yet.</p>";
                        return;
                    }

                    officeList.innerHTML = data.offices.map(office => {
                        const statusColor = office.isActive ? "var(--success)" : "var(--danger)";
                        return `
                    <div class="office-card">
                        <div>
                            <p><strong>${office.officeName}</strong></p>
                            <p style="opacity: 0.85;">${office.address}</p>
                            <p style="margin-top: 4px;">Contact: ${office.contactNumber}</p>
                            <p style="font-size: 13px; margin-top: 2px;">
                                Status: <span style="color: ${statusColor}; font-weight: 600;">${office.isActive ? "Active" : "Inactive"}</span>
                            </p>
                            <p style="font-size: 13px; opacity: 0.8;">Assigned Agent: <span style="font-weight: 500;">${office.assignedAgent ? office.assignedAgent.userName : "None"}</span></p>
                            <p style="font-size: 12px; opacity: 0.6; margin-top: 8px;">
                             ID: <code onclick="copyId('${office._id}')" style="background:#1f1f1f; color:var(--brand-accent); padding:2px 6px; border-radius:4px; cursor:pointer;" title="Click to copy">${office._id}</code>
                            </p>
                        </div>

                        <div class="office-actions">
                            <button class="btn-toggle" onclick="toggleOffice('${office._id}')">
                                ${office.isActive ? "Deactivate" : "Activate"}
                            </button>
                            <div class="btn-row">
                                <button class="btn-edit" onclick="editOffice('${office._id}', '${office.officeName}', '${office.address}', '${office.contactNumber}')">Edit</button>
                                <button class="btn-remove" onclick="removeOffice('${office._id}')">Remove</button>
                            </div>
                        </div>

                        <div style="margin-top: 16px; border-top: 1px solid var(--border-col); padding-top: 14px;">
                            <p style="font-weight: 600; margin-bottom: 10px;">Add Client for this office</p>
                            <form onsubmit="createClient(event, '${office._id}')">
                                <div style="margin-bottom: 10px;">
                                    <input type="text" name="userName" placeholder="Client username" required style="width:100%; padding:8px; border:1px solid var(--border-col); border-radius:6px; background:#1f1f1f; color:var(--text-light);" />
                                </div>
                                <div style="margin-bottom: 10px;">
                                    <input type="email" name="email" placeholder="Client email" required style="width:100%; padding:8px; border:1px solid var(--border-col); border-radius:6px; background:#1f1f1f; color:var(--text-light);" />
                                </div>
                                <div style="margin-bottom: 10px;">
                                    <input type="password" name="password" placeholder="Password" required style="width:100%; padding:8px; border:1px solid var(--border-col); border-radius:6px; background:#1f1f1f; color:var(--text-light);" />
                                </div>
                                <button type="submit" style="width:100%; padding:10px; font-size:14px;">Add Client</button>
                            </form>
                        </div>
                    </div>
                `}).join("");

                } catch (error) {
                    officeList.textContent = "Failed to load offices.";
                }
            }

            loadOffices();
            // ─────────────────────────────────
            // COPY OFFICE ID
            // ─────────────────────────────────
            function copyId(id) {
                navigator.clipboard.writeText(id);
                messageBox.textContent = "Office ID copied to clipboard!";
            }
            // ─────────────────────────────────
            // ADD OFFICE
            // ─────────────────────────────────
            document.getElementById("addForm").addEventListener("submit", async (e) => {
                e.preventDefault();
                const formData = new FormData(e.target);
                const body = Object.fromEntries(formData.entries());

                try {
                    const res = await fetch("/api/owner/offices", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        credentials: "include",
                        body: JSON.stringify(body),
                    });
                    const data = await res.json();

                    messageBox.textContent = data.message;
                    if (res.ok) {
                        e.target.reset();
                        loadOffices();
                    }

                } catch (error) {
                    messageBox.textContent = "Failed to add office.";
                }
            });

            // ─────────────────────────────────
            // TOGGLE STATUS
            // ─────────────────────────────────
            async function toggleOffice(id) {
                try {
                    const res = await fetch(`/api/owner/offices/${id}/status`, {
                        method: "PATCH",
                        credentials: "include",
                    });
                    const data = await res.json();

                    messageBox.textContent = data.message;
                    if (res.ok) loadOffices();

                } catch (error) {
                    messageBox.textContent = "Failed to toggle office status.";
                }
            }

            // ─────────────────────────────────
            // EDIT OFFICE
            // ─────────────────────────────────
            async function editOffice(id, currentName, currentAddress, currentContact) {
                const officeName = prompt("Office name:", currentName);
                if (officeName === null) return;

                const address = prompt("Address:", currentAddress);
                if (address === null) return;

                const contactNumber = prompt("Contact number:", currentContact);
                if (contactNumber === null) return;

                try {
                    const res = await fetch(`/api/owner/offices/${id}`, {
                        method: "PATCH",
                        headers: { "Content-Type": "application/json" },
                        credentials: "include",
                        body: JSON.stringify({ officeName, address, contactNumber }),
                    });
                    const data = await res.json();

                    messageBox.textContent = data.message;
                    if (res.ok) loadOffices();

                } catch (error) {
                    messageBox.textContent = "Failed to update office.";
                }
            }

            // ─────────────────────────────────
            // REMOVE OFFICE
            // ─────────────────────────────────
            async function removeOffice(id) {
                if (!confirm("Are you sure you want to remove this office?")) return;

                try {
                    const res = await fetch(`/api/owner/offices/${id}`, {
                        method: "DELETE",
                        credentials: "include",
                    });
                    const data = await res.json();

                    messageBox.textContent = data.message;
                    if (res.ok) loadOffices();

                } catch (error) {
                    messageBox.textContent = "Failed to remove office.";
                }
            }

            async function createClient(event, officeId) {
                event.preventDefault();
                const form = event.target;
                const formData = new FormData(form);
                const body = Object.fromEntries(formData.entries());
                body.office = officeId;

                try {
                    const res = await fetch("/api/owner/clients", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        credentials: "include",
                        body: JSON.stringify(body),
                    });
                    const data = await res.json();

                    messageBox.textContent = data.message;
                    if (res.ok) {
                        form.reset();
                        loadOffices();
                    }
                } catch (error) {
                    messageBox.textContent = "Failed to add client.";
                }
            }
        </script>

</body>

</html>