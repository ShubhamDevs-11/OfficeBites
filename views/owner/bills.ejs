<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head') %>
    <style>
        :root {
            --brand-dark: #222222;
            --brand-darker: #1a1a1a;
            --brand-accent: #89e900;
            --brand-accent-hover: #9dff10;
            --panel: #2a2a2a;
            --border-col: #3a3a3a;
            --text-light: #f2f2f2;
            --text-muted: #a8a8a8;
            --danger: #ff5c5c;
            --danger-hover: #ff3d3d;
            --success: #6ee06e;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background: radial-gradient(circle at top, #2b2b2b 0%, var(--brand-darker) 70%);
            color: var(--text-light);
            min-height: 100vh;
            padding: 0 0 40px 0;
        }

        .container {
            max-width: 1000px;
            margin: 40px auto;
            padding: 0 20px;
        }

        h2 {
            font-size: 26px;
            font-weight: 800;
            margin-bottom: 24px;
            letter-spacing: -0.5px;
            position: relative;
            padding-left: 14px;
        }

        h2::before {
            content: "";
            position: absolute;
            left: 0;
            top: 4px;
            bottom: 4px;
            width: 4px;
            background: var(--brand-accent);
            border-radius: 2px;
        }

        h3 {
            font-size: 17px;
            font-weight: 700;
            margin-bottom: 16px;
            padding-bottom: 10px;
            border-bottom: 1px solid var(--border-col);
            color: var(--text-light);
        }

        #message {
            margin-bottom: 24px;
            padding: 12px 14px;
            font-size: 14px;
            font-weight: 500;
            background-color: var(--panel);
            border: 1px solid var(--border-col);
            border-left: 4px solid var(--brand-accent);
            border-radius: 6px;
            color: var(--text-light);
        }
        #message:empty {
            display: none;
        }

        /* Responsive Dashboard split */
        .management-grid {
            display: grid;
            grid-template-columns: 360px 1fr;
            gap: 32px;
            align-items: start;
        }

        @media (max-width: 850px) {
            .management-grid {
                grid-template-columns: 1fr;
            }
        }

        .form-card {
            background: var(--panel);
            border: 1px solid var(--border-col);
            border-radius: 10px;
            padding: 24px;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
        }

        .form-group {
            margin-bottom: 16px;
        }

        label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 6px;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.4px;
        }

        input {
            width: 100%;
            padding: 10px 12px;
            font-size: 15px;
            border: 1px solid var(--border-col);
            border-radius: 8px;
            color: var(--text-light);
            background-color: #1f1f1f;
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }

        input:focus {
            outline: none;
            border-color: var(--brand-accent);
            box-shadow: 0 0 0 3px rgba(137, 233, 0, 0.18);
            background-color: #232323;
        }

        button[type="submit"] {
            width: 100%;
            padding: 11px;
            font-size: 15px;
            font-weight: 700;
            color: #111111;
            background-color: var(--brand-accent);
            border: none;
            border-radius: 8px;
            cursor: pointer;
            margin-top: 8px;
            transition: background-color 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
        }

        button[type="submit"]:hover {
            background-color: var(--brand-accent-hover);
            box-shadow: 0 0 20px rgba(137, 233, 0, 0.35);
            transform: translateY(-1px);
        }

        /* Dynamic Bills Cards Layout */
        .bill-list-container {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 16px;
        }

        .bill-card {
            background: var(--panel) !important;
            border: 1px solid var(--border-col) !important;
            border-radius: 10px !important;
            padding: 20px !important;
            margin-bottom: 0 !important;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3) !important;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            transition: border-color 0.2s ease, transform 0.15s ease;
        }

        .bill-card:hover {
            border-color: rgba(137, 233, 0, 0.35) !important;
            transform: translateY(-2px);
        }

        .bill-card p {
            font-size: 14px;
            margin-bottom: 6px;
            line-height: 1.4;
            color: var(--text-light);
        }

        .bill-card p strong {
            font-size: 16px;
            color: var(--text-light);
            display: block;
            margin-bottom: 4px;
        }

        .bill-actions {
            margin-top: 14px;
            display: flex;
            gap: 8px;
        }

        .bill-card button {
            flex: 1;
            padding: 8px 10px;
            font-size: 13px;
            font-weight: 600;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            transition: background-color 0.2s ease;
        }

        .btn-pay {
            background-color: var(--brand-accent);
            color: #111111;
        }

        .btn-pay:hover {
            background-color: var(--brand-accent-hover);
        }

        .btn-delete {
            background-color: #1f1f1f;
            color: var(--danger);
            border: 1px solid var(--border-col) !important;
        }

        .btn-delete:hover {
            background-color: #292929;
            color: var(--danger-hover);
        }
    </style>
</head>
<body>

    <%- include('../partials/nav') %>

    <div class="container">
        <h2>Billing</h2>

        <div id="message"></div>

        <div class="management-grid">
            <!-- Left Panel: Form creation -->
            <div class="form-card">
                <h3>Create New Bill</h3>
                <form id="addForm">
                    <div class="form-group">
                        <label>Office ID</label>
                        <input type="text" name="office" placeholder="Paste office ID from Offices page" required>
                    </div>
                    <div class="form-group">
                        <label>Amount</label>
                        <input type="number" name="amount" required>
                    </div>
                    <div class="form-group">
                        <label>Month (1-12)</label>
                        <input type="number" name="month" min="1" max="12" required>
                    </div>
                    <div class="form-group">
                        <label>Year</label>
                        <input type="number" name="year" required>
                    </div>
                    <button type="submit">Create Bill</button>
                </form>
            </div>

            <!-- Right Panel: List Content -->
            <div>
                <h3>All Bills</h3>
                <div id="billList" class="bill-list-container">
                    <p>Loading...</p>
                </div>
            </div>
        </div>
    </div>

    <script>
        const messageBox = document.getElementById("message");
        const billList = document.getElementById("billList");

        // ─────────────────────────────────
        // LOAD ALL BILLS
        // ─────────────────────────────────
        async function loadBills() {
            try {
                const res = await fetch("/api/owner/bills-data", {
                    credentials: "include",
                });
                const data = await res.json();

                if (!res.ok) {
                    billList.textContent = data.message;
                    return;
                }

                if (data.bills.length === 0) {
                    billList.innerHTML = "<p>No bills yet.</p>";
                    return;
                }

                billList.innerHTML = data.bills.map(bill => {
                    const isPending = bill.status === "pending";
                    const statusColor = isPending ? "var(--text-muted)" : "var(--success)";
                    const statusWeight = isPending ? "500" : "600";
                    
                    return `
                    <div class="bill-card">
                        <div>
                            <p><strong>${bill.office ? bill.office.officeName : "Unknown office"}</strong></p>
                            <p>Amount: <span style="font-weight: 600;">₹${bill.amount}</span></p>
                            <p style="opacity: 0.85;">Month/Year: ${bill.month}/${bill.year}</p>
                            <p style="margin-top: 4px; font-size: 13px;">Status: <span style="color: ${statusColor}; font-weight: ${statusWeight}; text-transform: uppercase;">${bill.status}</span></p>
                            ${bill.paidAt ? `<p style="font-size: 12px; opacity: 0.7;">Paid on: ${new Date(bill.paidAt).toLocaleDateString()}</p>` : ""}
                        </div>

                        <div class="bill-actions">
                            ${isPending ? `<button class="btn-pay" onclick="markPaid('${bill._id}')">Mark Paid</button>` : ""}
                            <button class="btn-delete" onclick="removeBill('${bill._id}')">Delete</button>
                        </div>
                    </div>
                `}).join("");

            } catch (error) {
                billList.textContent = "Failed to load bills.";
            }
        }

        loadBills();

        // ─────────────────────────────────
        // CREATE BILL
        // ─────────────────────────────────
        document.getElementById("addForm").addEventListener("submit", async (e) => {
            e.preventDefault();
            const formData = new FormData(e.target);
            const body = Object.fromEntries(formData.entries());

            try {
                const res = await fetch("/api/owner/bills", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    credentials: "include",
                    body: JSON.stringify(body),
                });
                const data = await res.json();

                messageBox.textContent = data.message;
                if (res.ok) {
                    e.target.reset();
                    loadBills();
                }

            } catch (error) {
                messageBox.textContent = "Failed to create bill.";
            }
        });

        // ─────────────────────────────────
        // MARK AS PAID
        // ─────────────────────────────────
        async function markPaid(id) {
            try {
                const res = await fetch(`/api/owner/bills/${id}/pay`, {
                    method: "PATCH",
                    credentials: "include",
                });
                const data = await res.json();

                messageBox.textContent = data.message;
                if (res.ok) loadBills();

            } catch (error) {
                messageBox.textContent = "Failed to mark bill as paid.";
            }
        }

        // ─────────────────────────────────
        // DELETE BILL
        // ─────────────────────────────────
        async function removeBill(id) {
            if (!confirm("Are you sure you want to delete this bill?")) return;

            try {
                const res = await fetch(`/api/owner/bills/${id}`, {
                    method: "DELETE",
                    credentials: "include",
                });
                const data = await res.json();

                messageBox.textContent = data.message;
                if (res.ok) loadBills();

            } catch (error) {
                messageBox.textContent = "Failed to delete bill.";
            }
        }
    </script>

</body>
</html>