<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head') %>
</head>
<body>

    <%- include('../partials/nav') %>

    <h2>Billing</h2>

    <div id="message"></div>

    <h3>Create New Bill</h3>
    <form id="addForm">
        <div>
            <label>Office ID</label>
            <input type="text" name="office" placeholder="Paste office ID from Offices page" required>
        </div>
        <div>
            <label>Amount</label>
            <input type="number" name="amount" required>
        </div>
        <div>
            <label>Month (1-12)</label>
            <input type="number" name="month" min="1" max="12" required>
        </div>
        <div>
            <label>Year</label>
            <input type="number" name="year" required>
        </div>
        <button type="submit">Create Bill</button>
    </form>

    <h3>All Bills</h3>
    <div id="billList">
        <p>Loading...</p>
    </div>

    <script>
        const messageBox = document.getElementById("message");
        const billList = document.getElementById("billList");

        // ─────────────────────────────────
        // LOAD ALL BILLS
        // ─────────────────────────────────
        async function loadBills() {
            try {
                const res = await fetch("/api/owner/bills-data", {
                    credentials: "include",
                });
                const data = await res.json();

                if (!res.ok) {
                    billList.textContent = data.message;
                    return;
                }

                if (data.bills.length === 0) {
                    billList.innerHTML = "<p>No bills yet.</p>";
                    return;
                }

                billList.innerHTML = data.bills.map(bill => `
                    <div style="border:1px solid #ccc; padding:10px; margin-bottom:10px;">
                        <p><strong>${bill.office ? bill.office.officeName : "Unknown office"}</strong></p>
                        <p>Amount: ₹${bill.amount}</p>
                        <p>Month/Year: ${bill.month}/${bill.year}</p>
                        <p>Status: ${bill.status}</p>
                        ${bill.paidAt ? `<p>Paid on: ${new Date(bill.paidAt).toLocaleDateString()}</p>` : ""}

                        ${bill.status === "pending" ? `<button onclick="markPaid('${bill._id}')">Mark as Paid</button>` : ""}
                        <button onclick="removeBill('${bill._id}')">Delete</button>
                    </div>
                `).join("");

            } catch (error) {
                billList.textContent = "Failed to load bills.";
            }
        }

        loadBills();

        // ─────────────────────────────────
        // CREATE BILL
        // ─────────────────────────────────
        document.getElementById("addForm").addEventListener("submit", async (e) => {
            e.preventDefault();
            const formData = new FormData(e.target);
            const body = Object.fromEntries(formData.entries());

            try {
                const res = await fetch("/api/owner/bills", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    credentials: "include",
                    body: JSON.stringify(body),
                });
                const data = await res.json();

                messageBox.textContent = data.message;
                if (res.ok) {
                    e.target.reset();
                    loadBills();
                }

            } catch (error) {
                messageBox.textContent = "Failed to create bill.";
            }
        });

        // ─────────────────────────────────
        // MARK AS PAID
        // ─────────────────────────────────
        async function markPaid(id) {
            try {
                const res = await fetch(`/api/owner/bills/${id}/pay`, {
                    method: "PATCH",
                    credentials: "include",
                });
                const data = await res.json();

                messageBox.textContent = data.message;
                if (res.ok) loadBills();

            } catch (error) {
                messageBox.textContent = "Failed to mark bill as paid.";
            }
        }

        // ─────────────────────────────────
        // DELETE BILL
        // ─────────────────────────────────
        async function removeBill(id) {
            if (!confirm("Are you sure you want to delete this bill?")) return;

            try {
                const res = await fetch(`/api/owner/bills/${id}`, {
                    method: "DELETE",
                    credentials: "include",
                });
                const data = await res.json();

                messageBox.textContent = data.message;
                if (res.ok) loadBills();

            } catch (error) {
                messageBox.textContent = "Failed to delete bill.";
            }
        }
    </script>

</body>
</html>