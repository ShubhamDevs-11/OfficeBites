<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head') %>
    <style>
        :root {
            --brand-dark: #222222;
            --brand-darker: #1a1a1a;
            --brand-accent: #89e900;
            --brand-accent-hover: #9dff10;
            --panel: #2a2a2a;
            --border-col: #3a3a3a;
            --text-light: #f2f2f2;
            --text-muted: #a8a8a8;
            --danger: #ff5c5c;
            --danger-hover: #ff3d3d;
            --success: #6ee06e;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background: radial-gradient(circle at top, #2b2b2b 0%, var(--brand-darker) 70%);
            color: var(--text-light);
            min-height: 100vh;
            padding: 0 0 40px 0;
        }

        .container {
            max-width: 1000px;
            margin: 40px auto;
            padding: 0 20px;
        }

        h2 {
            font-size: 26px;
            font-weight: 800;
            margin-bottom: 24px;
            letter-spacing: -0.5px;
            position: relative;
            padding-left: 14px;
        }

        h2::before {
            content: "";
            position: absolute;
            left: 0;
            top: 4px;
            bottom: 4px;
            width: 4px;
            background: var(--brand-accent);
            border-radius: 2px;
        }

        h3 {
            font-size: 17px;
            font-weight: 700;
            margin-bottom: 16px;
            padding-bottom: 10px;
            border-bottom: 1px solid var(--border-col);
            color: var(--text-light);
        }

        #message {
            margin-bottom: 24px;
            padding: 12px 14px;
            font-size: 14px;
            font-weight: 500;
            background-color: var(--panel);
            border: 1px solid var(--border-col);
            border-left: 4px solid var(--brand-accent);
            border-radius: 6px;
            color: var(--text-light);
        }
        #message:empty {
            display: none;
        }

        /* Two Column Layout for Management */
        .management-grid {
            display: grid;
            grid-template-columns: 380px 1fr;
            gap: 32px;
            align-items: start;
        }

        @media (max-width: 850px) {
            .management-grid {
                grid-template-columns: 1fr;
            }
        }

        .form-card {
            background: var(--panel);
            border: 1px solid var(--border-col);
            border-radius: 10px;
            padding: 24px;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
        }

        .form-group {
            margin-bottom: 16px;
        }

        label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 6px;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.4px;
        }

        input {
            width: 100%;
            padding: 10px 12px;
            font-size: 15px;
            border: 1px solid var(--border-col);
            border-radius: 8px;
            color: var(--text-light);
            background-color: #1f1f1f;
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }

        input:focus {
            outline: none;
            border-color: var(--brand-accent);
            box-shadow: 0 0 0 3px rgba(137, 233, 0, 0.18);
            background-color: #232323;
        }

        button[type="submit"] {
            width: 100%;
            padding: 11px;
            font-size: 15px;
            font-weight: 700;
            color: #111111;
            background-color: var(--brand-accent);
            border: none;
            border-radius: 8px;
            cursor: pointer;
            margin-top: 8px;
            transition: background-color 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
        }

        button[type="submit"]:hover {
            background-color: var(--brand-accent-hover);
            box-shadow: 0 0 20px rgba(137, 233, 0, 0.35);
            transform: translateY(-1px);
        }

        /* Dynamic List Container & Cards */
        .agent-list-container {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
            gap: 16px;
        }

        .agent-card {
            background: var(--panel) !important;
            border: 1px solid var(--border-col) !important;
            border-radius: 10px !important;
            padding: 18px !important;
            margin-bottom: 0 !important;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3) !important;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            transition: border-color 0.2s ease, transform 0.15s ease;
        }

        .agent-card:hover {
            border-color: rgba(137, 233, 0, 0.35) !important;
            transform: translateY(-2px);
        }

        .agent-card p {
            font-size: 14px;
            margin-bottom: 6px;
            line-height: 1.4;
            color: var(--text-light);
        }

        .agent-card p strong {
            font-size: 16px;
            color: var(--text-light);
        }

        .agent-card button {
            width: 100%;
            padding: 8px;
            font-size: 13px;
            font-weight: 600;
            color: #111111;
            background-color: var(--danger);
            border: none;
            border-radius: 6px;
            cursor: pointer;
            margin-top: 12px;
            transition: background-color 0.2s ease;
        }

        .agent-card button:hover {
            background-color: var(--danger-hover);
        }
    </style>
</head>
<body>

    <%- include('../partials/nav') %>

    <div class="container">
        <h2>Delivery Agents</h2>

        <div id="message"></div>

        <div class="management-grid">
            <!-- Left Side: Add Form -->
            <div class="form-card">
                <h3>Add New Agent</h3>
                <form id="addForm">
                    <div class="form-group">
                        <label>Username</label>
                        <input type="text" name="userName" required>
                    </div>
                    <div class="form-group">
                        <label>Email</label>
                        <input type="email" name="email" required>
                    </div>
                    <div class="form-group">
                        <label>Password</label>
                        <input type="password" name="password" required>
                    </div>
                    <div class="form-group">
                        <label>Phone</label>
                        <input type="tel" name="phone" required>
                    </div>
                    <button type="submit">Add Agent</button>
                </form>
            </div>

            <!-- Right Side: Agents Grid -->
            <div>
                <h3>All Agents</h3>
                <div id="agentList" class="agent-list-container">
                    <p>Loading...</p>
                </div>
            </div>
        </div>
    </div>

    <script>
        const messageBox = document.getElementById("message");
        const agentList = document.getElementById("agentList");

        // ─────────────────────────────────
        // LOAD ALL AGENTS
        // ─────────────────────────────────
        async function loadAgents() {
            try {
                const res = await fetch("/api/owner/agents-data", {
                    credentials: "include",
                });
                const data = await res.json();

                if (!res.ok) {
                    agentList.textContent = data.message;
                    return;
                }

                if (data.agents.length === 0) {
                    agentList.innerHTML = "<p>No agents yet.</p>";
                    return;
                }

                agentList.innerHTML = data.agents.map(agent => `
                    <div class="agent-card">
                        <div>
                            <p><strong>${agent.userName}</strong></p>
                            <p style="opacity: 0.85;">${agent.email}</p>
                            <p style="margin-top: 4px;">Phone: ${agent.phone}</p>
                            <p style="font-size: 13px; color: ${agent.isAvailable ? '#6ee06e' : '#ff5c5c'}; font-weight: 500;">
                                Available: ${agent.isAvailable ? "Yes" : "No"}
                            </p>
                        </div>
                        <button onclick="removeAgent('${agent._id}')">Remove</button>
                    </div>
                `).join("");

            } catch (error) {
                agentList.textContent = "Failed to load agents.";
            }
        }

        loadAgents();

        // ─────────────────────────────────
        // ADD AGENT
        // ─────────────────────────────────
        document.getElementById("addForm").addEventListener("submit", async (e) => {
            e.preventDefault();
            const formData = new FormData(e.target);
            const body = Object.fromEntries(formData.entries());

            try {
                const res = await fetch("/api/owner/agents", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    credentials: "include",
                    body: JSON.stringify(body),
                });
                const data = await res.json();

                messageBox.textContent = data.message;
                if (res.ok) {
                    e.target.reset();
                    loadAgents();
                }

            } catch (error) {
                messageBox.textContent = "Failed to add agent.";
            }
        });

        // ─────────────────────────────────
        // REMOVE AGENT
        // ─────────────────────────────────
        async function removeAgent(id) {
            if (!confirm("Are you sure you want to remove this agent?")) return;

            try {
                const res = await fetch(`/api/owner/agents/${id}`, {
                    method: "DELETE",
                    credentials: "include",
                });
                const data = await res.json();

                messageBox.textContent = data.message;
                if (res.ok) loadAgents();

            } catch (error) {
                messageBox.textContent = "Failed to remove agent.";
            }
        }
    </script>

</body>
</html>