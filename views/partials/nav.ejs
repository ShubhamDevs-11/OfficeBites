<script>
    async function logout() {
        try {
            await fetch("/api/auth/logout", {
                method: "POST",
                credentials: "include",
            });
            window.location.href = "/api/auth/login";
        } catch (error) {
            alert("Logout failed. Try again.");
        }
    }
</script>