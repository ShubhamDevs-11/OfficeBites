<nav class="top-nav">
    <div class="nav-brand">OfficeBites</div>
    <div id="portalLabel" class="portal-label">Owner Portal</div>
    <div class="nav-links" id="navLinks"></div>
    <button type="button" onclick="logout()">Logout</button>
</nav>

<script>
    const path = window.location.pathname;
    const navLinks = document.getElementById("navLinks");
    const portalLabel = document.getElementById("portalLabel");

    if (path.startsWith("/api/client")) {
        portalLabel.textContent = "Client Portal";
        navLinks.innerHTML = `
            <a href="/api/client/profile">Profile</a>
            <a href="/api/client/menu">Menu</a>
            <a href="/api/client/orders">Orders</a>
            <a href="/api/client/bills">Bills</a>
        `;
    } else {
        portalLabel.textContent = "Owner Portal";
        navLinks.innerHTML = `
            <a href="/api/owner/profile">Profile</a>
            <a href="/api/owner/menu">Menu</a>
            <a href="/api/owner/offices">Offices</a>
            <a href="/api/owner/agents">Agents</a>
            <a href="/api/owner/bills">Bills</a>
        `;
    }

    async function logout() {
        try {
            await fetch("/api/auth/logout", {
                method: "POST",
                credentials: "include",
            });
            window.location.href = "/api/auth/login";
        } catch (error) {
            alert("Logout failed. Try again.");
        }
    }
</script>