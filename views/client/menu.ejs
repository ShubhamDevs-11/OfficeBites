<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head') %>
    <style>
        :root {
            --brand-dark: #222222;
            --brand-darker: #1a1a1a;
            --brand-accent: #89e900;
            --brand-accent-hover: #9dff10;
            --panel: #2a2a2a;
            --border-col: #3a3a3a;
            --text-light: #f2f2f2;
            --text-muted: #a8a8a8;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background: radial-gradient(circle at top, #2b2b2b 0%, var(--brand-darker) 70%);
            color: var(--text-light);
            min-height: 100vh;
            padding: 0 0 40px 0;
        }

        .container {
            max-width: 1000px;
            margin: 40px auto;
            padding: 0 20px;
        }

        h2 {
            font-size: 26px;
            font-weight: 800;
            margin-bottom: 24px;
            letter-spacing: -0.5px;
            position: relative;
            padding-left: 14px;
        }

        h2::before {
            content: "";
            position: absolute;
            left: 0;
            top: 4px;
            bottom: 4px;
            width: 4px;
            background: var(--brand-accent);
            border-radius: 2px;
        }

        #message {
            margin-bottom: 24px;
            padding: 12px 14px;
            font-size: 14px;
            font-weight: 500;
            background-color: var(--panel);
            border: 1px solid var(--border-col);
            border-left: 4px solid var(--brand-accent);
            border-radius: 6px;
            color: var(--text-light);
        }
        #message:empty {
            display: none;
        }

        /* Responsive Menu Grid */
        .menu-grid-container {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
            gap: 20px;
        }

        .client-menu-card {
            background: var(--panel) !important;
            border: 1px solid var(--border-col) !important;
            border-radius: 10px !important;
            padding: 16px !important;
            margin-bottom: 0 !important;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3) !important;
            display: flex;
            flex-direction: column;
            transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
        }

        .client-menu-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4) !important;
            border-color: rgba(137, 233, 0, 0.35) !important;
        }

        .client-menu-card img {
            width: 100% !important;
            height: 160px !important;
            object-fit: cover !important;
            border-radius: 8px !important;
            margin-bottom: 12px !important;
            border: 1px solid var(--border-col);
            background-color: #1f1f1f;
        }

        .client-menu-card p {
            font-size: 14px;
            line-height: 1.4;
            color: var(--text-light);
        }

        .client-menu-card p strong {
            font-size: 16px;
            color: var(--text-light);
            display: block;
            margin-bottom: 4px;
        }

        .price-tag {
            font-size: 15px;
            font-weight: 700;
            color: var(--brand-accent);
            margin-top: auto;
            padding-top: 8px;
        }

        .order-call-banner {
            background: rgba(137, 233, 0, 0.1);
            border: 1px solid rgba(137, 233, 0, 0.4);
            color: var(--text-light);
            padding: 14px 18px;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 20px;
            display: inline-block;
        }

        .order-call-banner strong {
            color: var(--brand-accent);
        }
    </style>
</head>
<body>

    <%- include('../partials/nav') %>

    <div class="container">
        <h2>Available Menu</h2>
        <div class="order-call-banner">Call <strong>6351336621</strong> to order now</div>

        <div id="message"></div>

        <div id="itemList" class="menu-grid-container">
            <p>Loading...</p>
        </div>
    </div>

    <script>
        const messageBox = document.getElementById("message");
        const itemList = document.getElementById("itemList");

        async function loadItems() {
            try {
                const res = await fetch("/api/client/menu-data", {
                    credentials: "include",
                });
                const data = await res.json();

                if (!res.ok) {
                    itemList.textContent = data.message;
                    return;
                }

                if (data.items.length === 0) {
                    itemList.innerHTML = "<p>No items available right now.</p>";
                    return;
                }

                itemList.innerHTML = data.items.map(item => `
                    <div class="client-menu-card">
                        <img src="${item.itemPhoto}" alt="${item.itemName}">
                        <p><strong>${item.itemName}</strong></p>
                        <p class="price-tag">₹${item.itemPrice}</p>
                    </div>
                `).join("");

            } catch (error) {
                itemList.textContent = "Failed to load menu.";
            }
        }

        loadItems();
    </script>

</body>
</html>