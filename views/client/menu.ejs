<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head') %>
    <style>
        :root {
            --dark: #4A4A4A;
            --light-gray: #CBCBCB;
            --cream: #FFFFE3;
            --accent: #6D8196;
            --accent-hover: #556678;
            --card-bg: #FFFFFF;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--cream);
            color: var(--dark);
            min-height: 100vh;
            padding: 0 0 40px 0;
        }

        .container {
            max-width: 1000px;
            margin: 40px auto;
            padding: 0 20px;
        }

        h2 {
            font-size: 26px;
            font-weight: 600;
            margin-bottom: 24px;
            letter-spacing: -0.5px;
        }

        #message {
            margin-bottom: 24px;
            padding: 12px;
            font-size: 14px;
            font-weight: 500;
            background-color: #FFFFFF;
            border: 1px solid var(--light-gray);
            border-left: 4px solid var(--accent);
            border-radius: 4px;
        }
        #message:empty {
            display: none;
        }

        /* Responsive Menu Grid */
        .menu-grid-container {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
            gap: 20px;
        }

        .client-menu-card {
            background: var(--card-bg) !important;
            border: 1px solid var(--light-gray) !important;
            border-radius: 6px !important;
            padding: 16px !important;
            margin-bottom: 0 !important;
            box-shadow: 0 2px 6px rgba(74, 74, 74, 0.02) !important;
            display: flex;
            flex-direction: column;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .client-menu-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(74, 74, 74, 0.05) !important;
        }

        .client-menu-card img {
            width: 100% !important;
            height: 160px !important;
            object-fit: cover !important;
            border-radius: 4px !important;
            margin-bottom: 12px !important;
            border: 1px solid var(--light-gray);
            background-color: #FAFAFA;
        }

        .client-menu-card p {
            font-size: 14px;
            line-height: 1.4;
        }

        .client-menu-card p strong {
            font-size: 16px;
            color: var(--dark);
            display: block;
            margin-bottom: 4px;
        }

        .price-tag {
            font-size: 15px;
            font-weight: 600;
            color: var(--accent);
            margin-top: auto;
            padding-top: 8px;
        }
    </style>
</head>
<body>

    <%- include('../partials/nav') %>

    <div class="container">
        <h2>Available Menu</h2>

        <div id="message"></div>

        <div id="itemList" class="menu-grid-container">
            <p>Loading...</p>
        </div>
    </div>

    <script>
        const messageBox = document.getElementById("message");
        const itemList = document.getElementById("itemList");

        async function loadItems() {
            try {
                const res = await fetch("/api/client/menu-data", {
                    credentials: "include",
                });
                const data = await res.json();

                if (!res.ok) {
                    itemList.textContent = data.message;
                    return;
                }

                if (data.items.length === 0) {
                    itemList.innerHTML = "<p>No items available right now.</p>";
                    return;
                }

                itemList.innerHTML = data.items.map(item => `
                    <div class="client-menu-card">
                        <img src="${item.itemPhoto}" alt="${item.itemName}">
                        <p><strong>${item.itemName}</strong></p>
                        <p class="price-tag">₹${item.itemPrice}</p>
                    </div>
                `).join("");

            } catch (error) {
                itemList.textContent = "Failed to load menu.";
            }
        }

        loadItems();
    </script>

</body>
</html>