<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head') %>
    <style>
        :root {
            --brand-dark: #222222;
            --brand-darker: #1a1a1a;
            --brand-accent: #89e900;
            --brand-accent-hover: #9dff10;
            --panel: #2a2a2a;
            --border-col: #3a3a3a;
            --text-light: #f2f2f2;
            --text-muted: #a8a8a8;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background: radial-gradient(circle at top, #2b2b2b 0%, var(--brand-darker) 70%);
            color: var(--text-light);
            min-height: 100vh;
            padding: 0 0 40px 0;
        }

        .container {
            max-width: 800px;
            margin: 40px auto;
            padding: 0 20px;
        }

        h2 {
            font-size: 26px;
            font-weight: 800;
            margin-bottom: 24px;
            letter-spacing: -0.5px;
            position: relative;
            padding-left: 14px;
        }

        h2::before {
            content: "";
            position: absolute;
            left: 0;
            top: 4px;
            bottom: 4px;
            width: 4px;
            background: var(--brand-accent);
            border-radius: 2px;
        }

        #message {
            margin-bottom: 24px;
            padding: 12px 14px;
            font-size: 14px;
            font-weight: 500;
            background-color: var(--panel);
            border: 1px solid var(--border-col);
            border-left: 4px solid var(--brand-accent);
            border-radius: 6px;
            color: var(--text-light);
        }
        #message:empty {
            display: none;
        }

        /* Order List Grid Layout */
        .order-list-container {
            display: grid;
            grid-template-columns: 1fr;
            gap: 20px;
        }

        .order-card {
            background: var(--panel) !important;
            border: 1px solid var(--border-col) !important;
            border-radius: 10px !important;
            padding: 24px !important;
            margin-bottom: 0 !important;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3) !important;
            transition: border-color 0.2s ease, transform 0.15s ease;
        }

        .order-card:hover {
            border-color: rgba(137, 233, 0, 0.35) !important;
            transform: translateY(-2px);
        }

        .order-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            border-bottom: 1px solid var(--border-col);
            padding-bottom: 12px;
            margin-bottom: 16px;
        }

        @media (max-width: 600px) {
            .order-header {
                flex-direction: column;
                gap: 6px;
            }
        }

        .order-card p {
            font-size: 14px;
            line-height: 1.5;
            color: var(--text-light);
        }

        /* Clean styling for items list */
        .order-card ul {
            list-style: none;
            padding: 0;
            margin: 12px 0 16px 0;
            background-color: #1f1f1f;
            border-radius: 8px;
            border: 1px solid var(--border-col);
        }

        .order-card li {
            font-size: 14px;
            padding: 10px 14px;
            border-bottom: 1px solid var(--border-col);
            display: flex;
            justify-content: space-between;
            color: var(--text-light);
        }

        .order-card li:last-child {
            border-bottom: none;
        }

        .order-total-row {
            display: flex;
            justify-content: flex-end;
            align-items: center;
            font-size: 16px;
        }
    </style>
</head>
<body>

    <%- include('../partials/nav') %>

    <div class="container">
        <h2>Orders Delivered to My Office</h2>

        <div id="message"></div>

        <div id="orderList" class="order-list-container">
            <p>Loading...</p>
        </div>
    </div>

    <script>
        const messageBox = document.getElementById("message");
        const orderList = document.getElementById("orderList");

        async function loadOrders() {
            try {
                const res = await fetch("/api/client/orders-data", {
                    credentials: "include",
                });
                const data = await res.json();

                if (!res.ok) {
                    orderList.textContent = data.message;
                    return;
                }

                if (data.orders.length === 0) {
                    orderList.innerHTML = "<p>No orders delivered yet.</p>";
                    return;
                }

                orderList.innerHTML = data.orders.map(order => `
                    <div class="order-card">
                        <div class="order-header">
                            <div>
                                <p style="font-size: 13px; text-transform: uppercase; letter-spacing: 0.5px; opacity: 0.6; font-weight: 600;">Delivery Details</p>
                                <p style="margin-top: 2px;"><strong>Delivered on:</strong> ${new Date(order.deliveredAt).toLocaleString()}</p>
                            </div>
                            <div style="text-align: right; min-width: 150px;">
                                <p style="font-size: 13px; opacity: 0.85;"><strong>Agent:</strong> ${order.deliveryAgent ? order.deliveryAgent.userName : "Unknown"}</p>
                            </div>
                        </div>
                        
                        <p style="font-weight: 500; font-size: 13px; opacity: 0.7;">Items Ordered:</p>
                        <ul>
                            ${order.items.map(item => `
                                <li>
                                    <span>${item.itemName} <span style="opacity: 0.6; margin-left: 4px;">x ${item.quantity}</span></span>
                                    <span style="font-weight: 500;">₹${item.price}</span>
                                </li>
                            `).join("")}
                        </ul>
                        
                        <div class="order-total-row">
                            <p><strong>Total Paid:</strong> <span style="font-size: 18px; font-weight: 700; color: var(--brand-accent); margin-left: 6px;">₹${order.totalAmount}</span></p>
                        </div>
                    </div>
                `).join("");

            } catch (error) {
                orderList.textContent = "Failed to load orders.";
            }
        }

        loadOrders();
    </script>

</body>
</html>