<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head') %>
    <style>
        :root {
            --dark: #4A4A4A;
            --light-gray: #CBCBCB;
            --cream: #FFFFE3;
            --accent: #6D8196;
            --accent-hover: #556678;
            --card-bg: #FFFFFF;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--cream);
            color: var(--dark);
            min-height: 100vh;
            padding: 0 0 40px 0;
        }

        .container {
            max-width: 800px;
            margin: 40px auto;
            padding: 0 20px;
        }

        h2 {
            font-size: 26px;
            font-weight: 600;
            margin-bottom: 24px;
            letter-spacing: -0.5px;
        }

        #message {
            margin-bottom: 24px;
            padding: 12px;
            font-size: 14px;
            font-weight: 500;
            background-color: #FFFFFF;
            border: 1px solid var(--light-gray);
            border-left: 4px solid var(--accent);
            border-radius: 4px;
        }
        #message:empty {
            display: none;
        }

        /* Order List Grid Layout */
        .order-list-container {
            display: grid;
            grid-template-columns: 1fr;
            gap: 20px;
        }

        .order-card {
            background: var(--card-bg) !important;
            border: 1px solid var(--light-gray) !important;
            border-radius: 6px !important;
            padding: 24px !important;
            margin-bottom: 0 !important;
            box-shadow: 0 2px 6px rgba(74, 74, 74, 0.02) !important;
        }

        .order-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            border-bottom: 1px solid var(--light-gray);
            padding-bottom: 12px;
            margin-bottom: 16px;
        }

        @media (max-width: 600px) {
            .order-header {
                flex-direction: column;
                gap: 6px;
            }
        }

        .order-card p {
            font-size: 14px;
            line-height: 1.5;
        }

        /* Clean styling for items list */
        .order-card ul {
            list-style: none;
            padding: 0;
            margin: 12px 0 16px 0;
            background-color: #FAFAFA;
            border-radius: 4px;
            border: 1px solid #EAEAEA;
        }

        .order-card li {
            font-size: 14px;
            padding: 10px 14px;
            border-bottom: 1px solid #EAEAEA;
            display: flex;
            justify-content: space-between;
        }

        .order-card li:last-child {
            border-bottom: none;
        }

        .order-total-row {
            display: flex;
            justify-content: flex-end;
            align-items: center;
            font-size: 16px;
        }
    </style>
</head>
<body>

    <%- include('../partials/nav') %>

    <div class="container">
        <h2>Orders Delivered to My Office</h2>

        <div id="message"></div>

        <div id="orderList" class="order-list-container">
            <p>Loading...</p>
        </div>
    </div>

    <script>
        const messageBox = document.getElementById("message");
        const orderList = document.getElementById("orderList");

        async function loadOrders() {
            try {
                const res = await fetch("/api/client/orders-data", {
                    credentials: "include",
                });
                const data = await res.json();

                if (!res.ok) {
                    orderList.textContent = data.message;
                    return;
                }

                if (data.orders.length === 0) {
                    orderList.innerHTML = "<p>No orders delivered yet.</p>";
                    return;
                }

                orderList.innerHTML = data.orders.map(order => `
                    <div class="order-card">
                        <div class="order-header">
                            <div>
                                <p style="font-size: 13px; text-transform: uppercase; letter-spacing: 0.5px; opacity: 0.6; font-weight: 600;">Delivery Details</p>
                                <p style="margin-top: 2px;"><strong>Delivered on:</strong> ${new Date(order.deliveredAt).toLocaleString()}</p>
                            </div>
                            <div style="text-align: right; min-width: 150px;">
                                <p style="font-size: 13px; opacity: 0.85;"><strong>Agent:</strong> ${order.deliveryAgent ? order.deliveryAgent.userName : "Unknown"}</p>
                            </div>
                        </div>
                        
                        <p style="font-weight: 500; font-size: 13px; opacity: 0.7;">Items Ordered:</p>
                        <ul>
                            ${order.items.map(item => `
                                <li>
                                    <span>${item.itemName} <span style="opacity: 0.6; margin-left: 4px;">x ${item.quantity}</span></span>
                                    <span style="font-weight: 500;">₹${item.price}</span>
                                </li>
                            `).join("")}
                        </ul>
                        
                        <div class="order-total-row">
                            <p><strong>Total Paid:</strong> <span style="font-size: 18px; font-weight: 700; color: var(--dark); margin-left: 6px;">₹${order.totalAmount}</span></p>
                        </div>
                    </div>
                `).join("");

            } catch (error) {
                orderList.textContent = "Failed to load orders.";
            }
        }

        loadOrders();
    </script>

</body>
</html>