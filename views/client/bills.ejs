<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head') %>
    <style>
        :root {
            --brand-dark: #222222;
            --brand-darker: #1a1a1a;
            --brand-accent: #89e900;
            --brand-accent-hover: #9dff10;
            --panel: #2a2a2a;
            --border-col: #3a3a3a;
            --text-light: #f2f2f2;
            --text-muted: #a8a8a8;
            --success: #6ee06e;
            --warning: #ffb84d;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background: radial-gradient(circle at top, #2b2b2b 0%, var(--brand-darker) 70%);
            color: var(--text-light);
            min-height: 100vh;
            padding: 0 0 40px 0;
        }

        .container {
            max-width: 900px;
            margin: 40px auto;
            padding: 0 20px;
        }

        h2 {
            font-size: 26px;
            font-weight: 800;
            margin-bottom: 20px;
            letter-spacing: -0.5px;
            position: relative;
            padding-left: 14px;
        }

        h2::before {
            content: "";
            position: absolute;
            left: 0;
            top: 4px;
            bottom: 4px;
            width: 4px;
            background: var(--brand-accent);
            border-radius: 2px;
        }

        #message {
            margin-bottom: 20px;
            padding: 12px 14px;
            background: var(--panel);
            border: 1px solid var(--border-col);
            border-left: 4px solid var(--brand-accent);
            border-radius: 6px;
            font-size: 14px;
            color: var(--text-light);
        }

        #message:empty {
            display: none;
        }

        .bill-list {
            display: grid;
            gap: 14px;
        }

        .bill-card {
            background: var(--panel);
            border: 1px solid var(--border-col);
            border-radius: 10px;
            padding: 18px;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
            transition: border-color 0.2s ease, transform 0.15s ease;
        }

        .bill-card:hover {
            border-color: rgba(137, 233, 0, 0.35);
            transform: translateY(-2px);
        }

        .bill-card p {
            margin-bottom: 6px;
            font-size: 14px;
            color: var(--text-light);
        }

        .bill-card strong {
            color: var(--text-muted);
        }

        .status {
            display: inline-block;
            margin-top: 4px;
            padding: 4px 10px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }

        .status-paid {
            background: rgba(110, 224, 110, 0.14);
            color: var(--success);
        }

        .status-pending {
            background: rgba(255, 184, 77, 0.14);
            color: var(--warning);
        }
    </style>
</head>
<body>

    <%- include('../partials/nav') %>

    <div class="container">
        <h2>My Bills</h2>
        <div id="message"></div>
        <div id="billList" class="bill-list">
            <p>Loading...</p>
        </div>
    </div>

    <script>
        const messageBox = document.getElementById("message");
        const billList = document.getElementById("billList");

        async function loadBills() {
            try {
                const res = await fetch("/api/client/bills-data", {
                    credentials: "include",
                });
                const data = await res.json();

                if (!res.ok) {
                    billList.innerHTML = `<p>${data.message}</p>`;
                    return;
                }

                if (!data.bills || data.bills.length === 0) {
                    billList.innerHTML = "<p>No bills available yet.</p>";
                    return;
                }

                billList.innerHTML = data.bills.map(bill => {
                    const statusClass = bill.status === "paid" ? "status-paid" : "status-pending";
                    return `
                        <div class="bill-card">
                            <p><strong>Month:</strong> ${bill.month}/${bill.year}</p>
                            <p><strong>Amount:</strong> ₹${bill.amount}</p>
                            <p><strong>Status:</strong> <span class="status ${statusClass}">${bill.status}</span></p>
                            ${bill.paidAt ? `<p><strong>Paid On:</strong> ${new Date(bill.paidAt).toLocaleDateString()}</p>` : ""}
                        </div>
                    `;
                }).join("");

            } catch (error) {
                billList.innerHTML = "<p>Failed to load bills.</p>";
            }
        }

        loadBills();
    </script>

</body>
</html>