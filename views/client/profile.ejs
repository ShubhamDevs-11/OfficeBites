<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head') %>
        <style>
            :root {
                --brand-dark: #222222;
                --brand-darker: #1a1a1a;
                --brand-accent: #89e900;
                --brand-accent-hover: #9dff10;
                --panel: #2a2a2a;
                --border-col: #3a3a3a;
                --text-light: #f2f2f2;
                --text-muted: #a8a8a8;
            }

            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
                background: radial-gradient(circle at top, #2b2b2b 0%, var(--brand-darker) 70%);
                color: var(--text-light);
                min-height: 100vh;
                padding: 0 0 40px 0;
            }

            .container {
                max-width: 800px;
                margin: 40px auto;
                padding: 0 20px;
            }

            h2 {
                font-size: 26px;
                font-weight: 800;
                margin-bottom: 24px;
                letter-spacing: -0.5px;
                position: relative;
                padding-left: 14px;
            }

            h2::before {
                content: "";
                position: absolute;
                left: 0;
                top: 4px;
                bottom: 4px;
                width: 4px;
                background: var(--brand-accent);
                border-radius: 2px;
            }

            h3 {
                font-size: 17px;
                font-weight: 700;
                margin-bottom: 16px;
                padding-bottom: 10px;
                border-bottom: 1px solid var(--border-col);
                color: var(--text-light);
            }

            #message {
                margin-bottom: 24px;
                padding: 12px 14px;
                font-size: 14px;
                font-weight: 500;
                background-color: var(--panel);
                border: 1px solid var(--border-col);
                border-left: 4px solid var(--brand-accent);
                border-radius: 6px;
                min-height: 20px;
                color: var(--text-light);
            }

            #message:empty {
                display: none;
            }

            /* Profile Info Card Styles */
            #profileInfo {
                background: var(--panel);
                border: 1px solid var(--border-col);
                border-radius: 10px;
                padding: 24px;
                margin-bottom: 24px;
                box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
            }

            #profileInfo p {
                font-size: 15px;
                margin-bottom: 10px;
                line-height: 1.5;
                color: var(--text-light);
            }

            #profileInfo p:last-child {
                margin-bottom: 0;
            }

            #profileInfo strong {
                color: var(--brand-accent);
                font-weight: 600;
                display: inline-block;
                width: 100px;
            }

            .form-card {
                background: var(--panel);
                border: 1px solid var(--border-col);
                border-radius: 10px;
                padding: 24px;
                box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
            }

            .form-group {
                margin-bottom: 16px;
            }

            label {
                display: block;
                font-size: 13px;
                font-weight: 600;
                margin-bottom: 6px;
                color: var(--text-muted);
                text-transform: uppercase;
                letter-spacing: 0.4px;
            }

            input {
                width: 100%;
                padding: 10px 12px;
                font-size: 15px;
                border: 1px solid var(--border-col);
                border-radius: 8px;
                color: var(--text-light);
                background-color: #1f1f1f;
                transition: border-color 0.2s ease, box-shadow 0.2s ease;
            }

            input:focus {
                outline: none;
                border-color: var(--brand-accent);
                box-shadow: 0 0 0 3px rgba(137, 233, 0, 0.18);
                background-color: #232323;
            }

            button {
                width: 100%;
                padding: 12px;
                border: none;
                border-radius: 8px;
                background: var(--brand-accent);
                color: #111111;
                cursor: pointer;
                font-size: 15px;
                font-weight: 700;
                transition: background-color 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
            }

            button:hover {
                background: var(--brand-accent-hover);
                box-shadow: 0 0 20px rgba(137, 233, 0, 0.35);
                transform: translateY(-1px);
            }

            button:active {
                transform: translateY(0);
            }
        </style>
</head>

<body>

    <%- include('../partials/nav') %>

        <div class="container">
            <div class="profile-wrapper">

                <h2>My Profile</h2>

                <div id="message"></div>

                <div id="profileInfo">
                    <p>Loading...</p>
                </div>

                <div class="form-card">
                    <h3>Change Password</h3>

                    <form id="passwordForm">
                        <div class="form-group">
                            <label>Old Password</label>
                            <input type="password" name="oldPassword" required>
                        </div>

                        <div class="form-group">
                            <label>New Password</label>
                            <input type="password" name="newPassword" required>
                        </div>

                        <button type="submit">Change Password</button>
                    </form>
                </div>

            </div>
        </div>

        <script>
            const messageBox = document.getElementById("message");
            const profileInfo = document.getElementById("profileInfo");

            async function loadProfile() {
                try {
                    const res = await fetch("/api/client/profile-data", {
                        credentials: "include",
                    });
                    const data = await res.json();

                    if (!res.ok) {
                        profileInfo.textContent = data.message;
                        return;
                    }

                    const user = data.user;
                    profileInfo.innerHTML = `
                    <p><strong>Username:</strong> ${user.userName}</p>
                    <p><strong>Email:</strong> ${user.email}</p>
                    <p><strong>Office:</strong> ${user.office ? user.office.officeName : "Not assigned"}</p>
                `;

                } catch (error) {
                    profileInfo.textContent = "Failed to load profile.";
                }
            }

            loadProfile();

            document.getElementById("passwordForm").addEventListener("submit", async (e) => {
                e.preventDefault();
                const formData = new FormData(e.target);
                const body = Object.fromEntries(formData.entries());

                try {
                    const res = await fetch("/api/client/profile/password", {
                        method: "PATCH",
                        headers: { "Content-Type": "application/json" },
                        credentials: "include",
                        body: JSON.stringify(body),
                    });
                    const data = await res.json();

                    messageBox.textContent = data.message;
                    if (res.ok) e.target.reset();

                } catch (error) {
                    messageBox.textContent = "Failed to change password.";
                }
            });
        </script>

</body>

</html>