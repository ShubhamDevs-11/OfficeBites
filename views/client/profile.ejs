<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head') %>
        <style>
            :root {
                --dark: #4A4A4A;
                --light-gray: #CBCBCB;
                --cream: #FFFFE3;
                --accent: #6D8196;
                --accent-hover: #556678;
                --card-bg: #FFFFFF;
            }

            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
                background-color: var(--cream);
                color: var(--dark);
                min-height: 100vh;
                padding: 0 0 40px 0;
            }

            .container {
                max-width: 800px;
                margin: 40px auto;
                padding: 0 20px;
            }

            h2 {
                font-size: 26px;
                font-weight: 600;
                margin-bottom: 24px;
                letter-spacing: -0.5px;
            }

            h3 {
                font-size: 18px;
                font-weight: 600;
                margin-bottom: 16px;
                padding-bottom: 6px;
                border-bottom: 1px solid var(--light-gray);
            }

            #message {
                margin-bottom: 24px;
                padding: 12px;
                font-size: 14px;
                font-weight: 500;
                background-color: #FFFFFF;
                border: 1px solid var(--light-gray);
                border-left: 4px solid var(--accent);
                border-radius: 4px;
                min-height: 20px;
            }

            #message:empty {
                display: none;
            }

            /* Profile Info Card Styles */
            #profileInfo {
                background: var(--card-bg);
                border: 1px solid var(--light-gray);
                border-radius: 6px;
                padding: 24px;
                margin-bottom: 24px;
                box-shadow: 0 2px 8px rgba(74, 74, 74, 0.02);
            }

            #profileInfo p {
                font-size: 15px;
                margin-bottom: 10px;
                line-height: 1.5;
            }

            #profileInfo p:last-child {
                margin-bottom: 0;
            }

            #profileInfo strong {
                color: var(--dark);
                font-weight: 600;
                display: inline-block;
                width: 100px;
            }

            .form-group {
                margin-bottom: 16px;
            }

            label {
                display: block;
                font-size: 14px;
                font-weight: 500;
                margin-bottom: 6px;
            }

            input {
                width: 100%;
                padding: 10px 12px;
                font-size: 15px;
                border: 1px solid var(--light-gray);
                border-radius: 4px;
                color: var(--dark);
                background-color: #FAFAFA;
                transition: border-color 0.2s ease, box-shadow 0.2s ease;
            }

            input:focus {
                outline: none;
                border-color: var(--accent);
                box-shadow: 0 0 0 3px rgba(109, 129, 150, 0.15);
                background-color: #FFFFFF;
            }

            button {
                width: 100%;
                padding: 11px;
                border: none;
                border-radius: 4px;
                background: var(--accent);
                color: white;
                cursor: pointer;
                font-size: 15px;
                font-weight: 500;
                transition: background-color 0.2s ease;
            }

            button:hover {
                background: var(--accent-hover);
            }
        </style>
</head>

<body>

    <%- include('../partials/nav') %>

        <div class="container">
            <div class="profile-wrapper">

                <h2>My Profile</h2>

                <div id="message"></div>

                <div id="profileInfo">
                    <p>Loading...</p>
                </div>

                <div class="form-card">
                    <h3>Change Password</h3>

                    <form id="passwordForm">
                        <div class="form-group">
                            <label>Old Password</label>
                            <input type="password" name="oldPassword" required>
                        </div>

                        <div class="form-group">
                            <label>New Password</label>
                            <input type="password" name="newPassword" required>
                        </div>

                        <button type="submit">Change Password</button>
                    </form>
                </div>

            </div>
        </div>

        <script>
            const messageBox = document.getElementById("message");
            const profileInfo = document.getElementById("profileInfo");

            async function loadProfile() {
                try {
                    const res = await fetch("/api/client/profile-data", {
                        credentials: "include",
                    });
                    const data = await res.json();

                    if (!res.ok) {
                        profileInfo.textContent = data.message;
                        return;
                    }

                    const user = data.user;
                    profileInfo.innerHTML = `
                    <p><strong>Username:</strong> ${user.userName}</p>
                    <p><strong>Email:</strong> ${user.email}</p>
                    <p><strong>Office:</strong> ${user.office ? user.office.officeName : "Not assigned"}</p>
                `;

                } catch (error) {
                    profileInfo.textContent = "Failed to load profile.";
                }
            }

            loadProfile();

            document.getElementById("passwordForm").addEventListener("submit", async (e) => {
                e.preventDefault();
                const formData = new FormData(e.target);
                const body = Object.fromEntries(formData.entries());

                try {
                    const res = await fetch("/api/client/profile/password", {
                        method: "PATCH",
                        headers: { "Content-Type": "application/json" },
                        credentials: "include",
                        body: JSON.stringify(body),
                    });
                    const data = await res.json();

                    messageBox.textContent = data.message;
                    if (res.ok) e.target.reset();

                } catch (error) {
                    messageBox.textContent = "Failed to change password.";
                }
            });
        </script>

</body>

</html>