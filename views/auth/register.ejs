<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register - OfficeBites</title>
    <style>
        :root {
            --brand-dark: #222222;
            --brand-darker: #1a1a1a;
            --brand-accent: #89e900;
            --brand-accent-hover: #9dff10;
            --panel: #2a2a2a;
            --border-col: #3a3a3a;
            --text-light: #f2f2f2;
            --text-muted: #a8a8a8;
            --error: #ff5c5c;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background: radial-gradient(circle at top, #2b2b2b 0%, var(--brand-darker) 70%);
            color: var(--text-light);
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 40px 20px;
        }

        .register-container {
            background: var(--panel);
            border: 1px solid var(--border-col);
            border-radius: 12px;
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.45), 0 0 0 1px rgba(137, 233, 0, 0.04);
            width: 100%;
            max-width: 440px;
            padding: 40px 32px;
        }

        h2 {
            font-size: 26px;
            font-weight: 800;
            margin-bottom: 6px;
            text-align: center;
            color: var(--text-light);
            letter-spacing: -0.5px;
        }

        h2::after {
            content: "";
            display: block;
            width: 48px;
            height: 3px;
            background: var(--brand-accent);
            border-radius: 2px;
            margin: 12px auto 24px;
        }

        #message {
            margin-bottom: 16px;
            font-size: 14px;
            color: var(--error);
            text-align: center;
            font-weight: 500;
            min-height: 20px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 6px;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.4px;
        }

        input,
        select {
            width: 100%;
            padding: 11px 14px;
            font-size: 15px;
            border: 1px solid var(--border-col);
            border-radius: 8px;
            color: var(--text-light);
            background-color: #1f1f1f;
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }

        input::placeholder {
            color: #6b6b6b;
        }

        select {
            appearance: none;
            background-image: linear-gradient(45deg, transparent 50%, var(--brand-accent) 50%), linear-gradient(135deg, var(--brand-accent) 50%, transparent 50%);
            background-position: calc(100% - 20px) center, calc(100% - 15px) center;
            background-size: 5px 5px, 5px 5px;
            background-repeat: no-repeat;
        }

        input:focus,
        select:focus {
            outline: none;
            border-color: var(--brand-accent);
            box-shadow: 0 0 0 3px rgba(137, 233, 0, 0.18);
            background-color: #232323;
        }

        button[type="submit"] {
            width: 100%;
            padding: 13px;
            font-size: 16px;
            font-weight: 700;
            color: #111111;
            background-color: var(--brand-accent);
            border: none;
            border-radius: 8px;
            cursor: pointer;
            margin-top: 10px;
            letter-spacing: 0.2px;
            transition: background-color 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
        }

        button[type="submit"]:hover {
            background-color: var(--brand-accent-hover);
            box-shadow: 0 0 20px rgba(137, 233, 0, 0.35);
            transform: translateY(-1px);
        }

        button[type="submit"]:active {
            transform: translateY(0);
        }

        .footer-text {
            margin-top: 24px;
            text-align: center;
            font-size: 14px;
            color: var(--text-muted);
        }

        .footer-text a {
            color: var(--brand-accent);
            text-decoration: none;
            font-weight: 600;
        }

        .footer-text a:hover {
            text-decoration: underline;
        }
    </style>
</head>

<body>

    <div class="register-container">
        <h2>Register</h2>

        <div id="message"></div>

        <form id="registerForm">
            <div class="form-group">
                <label>Username</label>
                <input type="text" name="userName" required>
            </div>

            <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" required>
            </div>

            <div class="form-group">
                <label>Password</label>
                <input type="password" name="password" required>
            </div>

            <div id="companyWrapper" class="form-group">
                <label>Company Name</label>
                <input type="text" name="companyName" id="companyField" required>
            </div>

            <input type="hidden" name="role" value="owner">
            <button type="submit">Register</button>
        </form>

        <p class="footer-text">Already have an account? <a href="/api/auth/login">Login</a></p>
    </div>

    <script>
        const form = document.getElementById("registerForm");
        const messageBox = document.getElementById("message");

        form.addEventListener("submit", async (e) => {
            e.preventDefault();

            const formData = new FormData(form);
            const body = Object.fromEntries(formData.entries());

            try {
                const res = await fetch("/api/auth/register", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    credentials: "include",
                    body: JSON.stringify(body),
                });

                const data = await res.json();

                if (!res.ok) {
                    messageBox.textContent = data.message;
                    return;
                }

                // redirect based on role
                if (data.user.role === "owner") {
                    window.location.href = "/api/owner/profile";
                } else if (data.user.role === "client") {
                    window.location.href = "/api/client/profile";
                } else {
                    window.location.href = "/api/agent/dashboard";
                }

            } catch (error) {
                messageBox.textContent = "Something went wrong. Try again.";
            }
        });
    </script>

</body>

</html>